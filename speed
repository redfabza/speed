    updateBoxText()
end)

Minus100Btn.MouseButton1Click:Connect(function()
    TARGET_SPEED = math.max(0, TARGET_SPEED - 100)
    updateBoxText()
end)

Plus100Btn.MouseButton1Click:Connect(function()
    TARGET_SPEED = TARGET_SPEED + 100
    updateBoxText()
end)

-- ==========================================
-- CORE LOGIC
-- ==========================================
SpeedConnection = RunService.Stepped:Connect(function()
    if SPEED_ENABLED then
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum and hum.WalkSpeed ~= TARGET_SPEED then
            hum.WalkSpeed = TARGET_SPEED
        end
    end
end)

