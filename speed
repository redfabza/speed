-- ==========================================
-- INTERACTION LOGIC
-- ==========================================
local function updateBoxText()
    SpeedInputBox.Text = tostring(TARGET_SPEED)
end

SpeedInputBox.FocusLost:Connect(function(enterPressed)
    local inputNum = tonumber(SpeedInputBox.Text)
    if inputNum then
        TARGET_SPEED = math.max(0, inputNum)
    end
    updateBoxText()
end)

ToggleBtn.MouseButton1Click:Connect(function()
    SPEED_ENABLED = not SPEED_ENABLED
    updateToggleStyle()
    if not SPEED_ENABLED then
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed = DEFAULT_SPEED end
    end
end)

TinyMinusBtn.MouseButton1Click:Connect(function()
    TARGET_SPEED = math.max(0, TARGET_SPEED - 1)
    updateBoxText()
end)

TinyPlusBtn.MouseButton1Click:Connect(function()
    TARGET_SPEED = TARGET_SPEED + 1
    updateBoxText()
end)

MinusBtn.MouseButton1Click:Connect(function()
    TARGET_SPEED = math.max(0, TARGET_SPEED - 10)
    updateBoxText()
end)

PlusBtn.MouseButton1Click:Connect(function()
